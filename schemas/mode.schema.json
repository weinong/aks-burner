{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/fields",
  "required": ["iterations", "iterationsPerNamespace", "qps", "burst", "cleanup", "waitWhenFinished", "preLoadImages", "reporting", "templateVars", "imageVars"],
  "$defs": {
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "iterations": { "type": "integer", "minimum": 1 },
        "iterationsPerNamespace": { "type": "integer", "minimum": 1 },
        "qps": { "type": "integer", "minimum": 1 },
        "burst": { "type": "integer", "minimum": 1 },
        "cleanup": { "type": "boolean" },
        "waitWhenFinished": { "type": "boolean" },
        "preLoadImages": { "type": "boolean" },
        "jobPause": { "type": "string", "minLength": 1 },
        "metricsClosing": { "enum": ["afterJob", "afterJobPause", "afterMeasurements"] },
        "workloadFile": { "type": "string", "minLength": 1 },
        "artifactSubpath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\{\\{\\.runTimestamp\\}\\}[A-Za-z0-9._-]*$",
          "not": { "pattern": "\\.\\." }
        },
        "reporting": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scheme"],
          "properties": {
            "scheme": { "type": "string", "enum": ["standard-summary", "kube-burner", "pod-ready", "storage-startup"] }
          }
        },
        "templateVars": { "type": "object", "additionalProperties": true },
        "imageVars": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
